# ===========================================
# 数智瞭望系统前端环境变量配置示例
# 只有 VITE_API_BASE_URL 在代码中被使用，其他配置项目前为预留项，可在后续开发中扩展使用。
# ===========================================
# 复制此文件为 .env.local 或 .env.production 并修改配置

# -------------------------------------------
# API 服务配置
# -------------------------------------------

# 后端 API 基础地址
# 开发环境示例: http://localhost:8000/api/v1
# 生产环境示例: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws

# -------------------------------------------
# 应用配置（可选）
# -------------------------------------------

# 应用标题
VITE_APP_TITLE=数智瞭望系统

# 应用版本
VITE_APP_VERSION=1.0.0

# -------------------------------------------
# 功能开关（可选）
# -------------------------------------------

# 是否启用调试模式
VITE_DEBUG=false

# 是否启用 mock 数据（用于无后端开发）
VITE_ENABLE_MOCK=false

# -------------------------------------------
# 第三方服务配置（可选）
# -------------------------------------------

# 文件上传服务地址（如果与 API 地址不同）
# VITE_FILE_UPLOAD_URL=

# WebSocket 服务地址（用于实时消息）
# VITE_WS_URL=ws://localhost:8000/ws

# -------------------------------------------
# 日志配置（可选）
# -------------------------------------------

# 日志级别: debug, info, warn, error
VITE_LOG_LEVEL=info

# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=false