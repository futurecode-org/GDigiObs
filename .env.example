# Uvicorn 配置
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# MySQL 配置
DATABASE_HOST=47.109.147.74
DATABASE_PORT=3306
DATABASE_NAME=cdut_liaowang
DATABASE_USER=cdut_liaowang
DATABASE_PASSWORD=your_password

# JWT 配置
JWT_SECRET_KEY=your_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# 初始化超级管理员信息
INITIAL_SUPER_ADMIN_USERNAME=admin
INITIAL_SUPER_ADMIN_PASSWORD=admin123
INITIAL_SUPER_ADMIN_EMAIL=admin@example.com
INITIAL_SUPER_ADMIN_PHONE=13800000000
INITIAL_SUPER_ADMIN_NICKNAME=超级管理员

# CORS 配置
# 允许的源，多个域名用逗号分隔，例如: http://localhost:3000,http://localhost:8080
# 生产环境应配置具体域名，开发环境可使用 *
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
# 允许的方法，多个方法用逗号分隔，例如: GET,POST,PUT,DELETE
CORS_ALLOW_METHODS=*
# 允许的头部，多个头部用逗号分隔
CORS_ALLOW_HEADERS=*
# 生产环境示例：
# CORS_ALLOW_ORIGINS=https://example.com,https://admin.example.com
# CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=Content-Type,Authorization
